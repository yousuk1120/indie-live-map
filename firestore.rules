rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // [보안 규칙 함수 정의]
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated();
    }

    // 1. 정식 공연 데이터 (홈페이지 노출용: 누구나 읽기 가능)
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. 관리자 파이프라인 전용 데이터 (오직 관리자만 읽고 쓰기 가능)
    match /source_accounts/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /raw_posts/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /candidate_events/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
