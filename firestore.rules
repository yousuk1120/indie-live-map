rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // [보안 규칙 함수 정의]
    // ─────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // 관리자 판정: 로그인만으로는 부족 — 허용된 이메일 화이트리스트로 제한합니다.
    // 새 관리자를 추가하려면 아래 배열에 이메일을 추가한 뒤 rules를 재배포하세요.
    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email != null
        && request.auth.token.email in [
          'yousuk1120@gmail.com'
        ];
    }

    function isOptionalString(data, field, maxLen) {
      return !(field in data)
        || (data[field] is string && data[field].size() <= maxLen);
    }

    // 공연 문서 스키마 검증: 허용된 필드만, 타입과 길이 제한 강제
    function isValidEvent() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'title', 'date', 'time', 'venueName', 'artistNames',
          'sourceUrl', 'instagramUrl', 'price', 'posterUrl',
          'createdAt', 'autoPublished'
        ])
        && d.title is string
        && d.title.size() > 0
        && d.title.size() <= 300
        && isOptionalString(d, 'date', 60)
        && isOptionalString(d, 'time', 60)
        && isOptionalString(d, 'venueName', 200)
        && isOptionalString(d, 'artistNames', 1000)
        && isOptionalString(d, 'sourceUrl', 1000)
        && isOptionalString(d, 'instagramUrl', 1000)
        && isOptionalString(d, 'price', 500)
        && isOptionalString(d, 'posterUrl', 2000)
        && (!('autoPublished' in d) || d.autoPublished is bool);
    }

    // ─────────────────────────────────────────
    // 1. 정식 공연 데이터 (홈페이지 노출용: 누구나 읽기 가능)
    //    쓰기는 화이트리스트 관리자 + 스키마 검증 통과 시에만 허용
    // ─────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidEvent();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────
    // 2. 관리자 파이프라인 전용 데이터 (오직 관리자만 읽고 쓰기 가능)
    // ─────────────────────────────────────────
    match /source_accounts/{docId} {
      allow read, write: if isAdmin();
    }

    match /raw_posts/{docId} {
      allow read, write: if isAdmin();
    }

    match /candidate_events/{docId} {
      allow read, write: if isAdmin();
    }

    // 그 외 모든 컬렉션은 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
